{
  // Editor del curso, configurado a nivel proyecto para que sea consistente
  // entre todos los alumnos, sin depender de la config global de cada uno.

  // Formateo con Prettier al guardar, usando el .prettierrc del proyecto.
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[json]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[jsonc]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },

  // Corrector ortográfico en español e inglés; la jerga técnica del curso se
  // agrega en cspell.json. Se limita a markdown (la teoría): en los `.ts` los
  // identificadores en español generan ruido sin valor.
  "cSpell.language": "es,en",
  "cSpell.enableFiletypes": ["!typescript"]
}
